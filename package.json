{
  "name": "global-job-search",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @gjs/web dev",
    "build": "pnpm --filter @gjs/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run --passWithNoTests",
    "db:generate": "pnpm --filter @gjs/web exec drizzle-kit generate",
    "db:migrate": "pnpm --filter @gjs/web exec drizzle-kit migrate"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
