{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "WebSearch"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git push origin main*)",
      "Bash(git branch -D*)",
      "Bash(git add .)",
      "Bash(git add . *)",
      "Bash(git add -A*)",
      "Bash(git add --all*)",
      "Bash(git commit -m *)",
      "Bash(git commit -m\"*)",
      "Bash(git commit -m'*)",
      "Bash(git commit -am *)",
      "Bash(git commit -am\"*)",
      "Bash(git commit -am'*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-files.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/git-commit-guard.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-pr-checks.sh"
          }
        ]
      }
    ]
  }
}
