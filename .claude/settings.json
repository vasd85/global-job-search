{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "WebSearch",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git add *)",
      "Bash(git rm *)",
      "Bash(git mv *)",
      "Bash(git restore *)",
      "Bash(git stash*)",
      "Bash(git rebase*)",
      "Bash(git commit -F*)",
      "Bash(git commit --amend*)",
      "Bash(git push*)",
      "Bash(gh pr create*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr comment*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr ready*)",
      "Bash(gh issue*)",
      "Bash(gh repo view*)",
      "Bash(gh api*)",
      "Bash(gh auth status*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git push origin main*)",
      "Bash(git branch -D*)",
      "Bash(git add .)",
      "Bash(git add . *)",
      "Bash(git add -A*)",
      "Bash(git add --all*)",
      "Bash(git commit -m *)",
      "Bash(git commit -m\"*)",
      "Bash(git commit -m'*)",
      "Bash(git commit -am *)",
      "Bash(git commit -am\"*)",
      "Bash(git commit -am'*)",
      "Read(**/.env)",
      "Read(**/.env.local)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-files.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/git-commit-guard.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-pr-checks.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-approve-safe-ops.sh"
          }
        ]
      }
    ]
  }
}
